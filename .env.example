# Copy to ".env" and replace placeholder values.
# Generate JWT: python -c "import secrets; print(secrets.token_urlsafe(48))"

FLASK_APP=app
FLASK_ENV=development
FLASK_DEBUG=1

POSTGRES_USER=myuser
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_DB=baby_data_db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://myuser:change-me@db:5432/baby_data_db

JWT_SECRET_KEY=replace-with-long-random-string
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me

DATA_FILES_DIR=etl/data_files/
